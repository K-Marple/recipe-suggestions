@page "/mealdbrecipe/{MealId}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using recipe_suggestions.Data
@using recipe_suggestions.Models
@using recipe_suggestions.Services
@using System.Globalization
@inject MealDbService MealDb
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject PantryService Pantry
@inject NavigationManager Nav
@inject RecipeSearchState RecipeState

<PageTitle>Recipe Details</PageTitle>

<div class="wireframe-page compact-page detail-screen">

@if (isLoading)
{
    <section class="wireframe-section empty-state">
        <div class="empty-art"><i class="bi bi-hourglass-split" aria-hidden="true"></i></div>
        <h1>Loading recipe...</h1>
        <p>Getting full recipe details from TheMealDB.</p>
    </section>
}
else if (meal == null)
{
    <section class="wireframe-section empty-state">
        <div class="empty-art"><i class="bi bi-exclamation-circle" aria-hidden="true"></i></div>
        <h1>Recipe could not load</h1>
        <p>
            @(mealDbFailed
                ? "TheMealDB could not be reached. Check your internet connection and try again."
                : "This recipe was not found in TheMealDB.")
        </p>
        <a class="wire-btn primary" href="/ingredients">Back to Pantry</a>
    </section>
}
else
{
    var estimate = GetRecipeEstimate();
    var ingredients = meal.GetIngredientsWithMeasures().ToList();
    var haveCount = matchStats?.HaveFromPantry ?? 0;
    var dontHaveCount = matchStats?.BuyCount ?? ingredients.Count;
    var steps = meal.GetInstructionSteps().ToList();

    <div class="recipe-detail-page">
        <main class="recipe-detail-main">
            <button type="button" class="back-link detail-back-link" @onclick="BackToResults">
                <i class="bi bi-arrow-left" aria-hidden="true"></i>
                Back to Results
            </button>

            <section class="detail-hero-grid">
                <div class="recipe-detail-image-box">
                    <img src="@meal.StrMealThumb" alt="Photo of @meal.StrMeal" />
                </div>

                <div class="recipe-detail-summary">
                    <h1>@meal.StrMeal</h1>

                    <div class="detail-meta-row">
                        <span class="match-count-pill">@haveCount have / @dontHaveCount don't have</span>
                        <span><i class="bi bi-clock" aria-hidden="true"></i> @estimate.TotalMinutes mins</span>
                        <span aria-hidden="true">:</span>
                        <span><i class="bi bi-bar-chart-fill" aria-hidden="true"></i> @estimate.Difficulty</span>
                    </div>

                    <p>@GetRecipeDescription()</p>

                    <div class="detail-actions detail-hero-actions">
                        <button type="button"
                                class="icon-button @(savedRecipe?.IsFavorite == true ? "favorited" : "")"
                                aria-label="@(savedRecipe?.IsFavorite == true ? "Unfavorite recipe" : "Favorite recipe")"
                                aria-pressed="@(savedRecipe?.IsFavorite == true)"
                                @onclick="ToggleFavorite">
                            <i class="bi @(savedRecipe?.IsFavorite == true ? "bi-heart-fill" : "bi-heart")" aria-hidden="true"></i>
                        </button>
                        <button type="button"
                                class="icon-button @(savedRecipe != null ? "saved" : "")"
                                aria-label="@(savedRecipe != null ? "Unsave recipe" : "Save recipe")"
                                aria-pressed="@(savedRecipe != null)"
                                @onclick="ToggleSaved">
                            <i class="bi @(savedRecipe != null ? "bi-bookmark-fill" : "bi-bookmark")" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            </section>

            <section class="detail-info-row">
                <section class="detail-stats-card" aria-label="Recipe facts">
                    <div>
                        <span><i class="bi bi-person" aria-hidden="true"></i> Serves</span>
                        <strong>@servings</strong>
                    </div>
                    <div>
                        <span><i class="bi bi-clock" aria-hidden="true"></i> Prep</span>
                        <strong>@estimate.PrepMinutes mins</strong>
                    </div>
                    <div>
                        <span><i class="bi bi-basket" aria-hidden="true"></i> Cook</span>
                        <strong>@estimate.CookMinutes mins</strong>
                    </div>
                    <div>
                        <span><i class="bi bi-leaf" aria-hidden="true"></i> Cuisine</span>
                        <strong>@(string.IsNullOrWhiteSpace(meal.StrArea) ? "Global" : meal.StrArea)</strong>
                    </div>
                    <div>
                        <span><i class="bi bi-tag" aria-hidden="true"></i> Category</span>
                        <strong>@(string.IsNullOrWhiteSpace(meal.StrCategory) ? "Dinner" : meal.StrCategory)</strong>
                    </div>
                </section>

                <section class="cooking-tip-card">
                    <i class="bi bi-lightbulb" aria-hidden="true"></i>
                    <div>
                        <h2>Cooking Tip</h2>
                        <p>@GetCookingTip()</p>
                    </div>
                </section>
            </section>

            <section class="detail-content-grid">
                <div class="detail-ingredients-panel" id="ingredients-section">
                    <h2>Ingredients</h2>
                    <div class="serving-control" aria-label="Servings">
                        <span>Serves</span>
                        <strong>@servings</strong>
                    </div>

                    <ul class="detail-ingredient-list">
                        @foreach (var (ingredient, measure) in ingredients)
                        {
                            var hasIt = pantryNames.Any(p => IngredientMatcher.Matches(p, ingredient));
                            <li class="@(hasIt ? "have" : "need")">
                                <span class="ingredient-status" aria-label="@(hasIt ? "In your pantry" : "Not in your pantry")">
                                    <i class="bi @(hasIt ? "bi-check-lg" : "bi-circle")"></i>
                                </span>
                                <span>@FormatIngredientLine(measure, ingredient)</span>
                            </li>
                        }
                    </ul>
                </div>

                <div class="detail-instructions-panel" id="instructions-section">
                    <h2>Instructions</h2>
                    <ol class="detail-instruction-list">
                        @for (var i = 0; i < steps.Count; i++)
                        {
                            <li>
                                <span>@(i + 1)</span>
                                <p>@steps[i]</p>
                            </li>
                        }
                    </ol>
                </div>
            </section>
        </main>
    </div>
}

@if (showLoginPrompt)
{
    <div class="modal-backdrop" @onclick="CloseLoginPrompt">
        <section class="app-modal recipe-auth-modal" role="dialog" aria-modal="true" aria-labelledby="detail-login-title" @onclick:stopPropagation="true">
            <button type="button" class="modal-close" aria-label="Close" @onclick="CloseLoginPrompt">&times;</button>
            <h2 id="detail-login-title">Log in to save recipes</h2>
            <p>Log in or create an account to save and favorite this meal.</p>
            <div class="modal-actions recipe-auth-actions">
                <button type="button" class="wire-btn secondary" @onclick="CloseLoginPrompt">Not Now</button>
                <button type="button" class="wire-btn primary" @onclick="GoToLogin">Log In</button>
            </div>
        </section>
    </div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="modal-backdrop" @onclick="CloseErrorPopup">
        <section class="app-modal recipe-auth-modal" role="alertdialog" aria-modal="true" aria-labelledby="detail-error-title" @onclick:stopPropagation="true">
            <button type="button" class="modal-close" aria-label="Close" @onclick="CloseErrorPopup">&times;</button>
            <h2 id="detail-error-title">Something went wrong</h2>
            <p>@errorMessage</p>
            <div class="modal-actions"><button type="button" class="wire-btn primary" @onclick="CloseErrorPopup">OK</button></div>
        </section>
    </div>
}

</div>

@code {
    [Parameter]
    public string MealId { get; set; } = "";

    [SupplyParameterFromQuery(Name = "source")]
    public string? Source { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string BackToResultsUrl =>
        !string.IsNullOrWhiteSpace(ReturnUrl) && ReturnUrl.StartsWith('/') && !ReturnUrl.StartsWith("//")
            ? ReturnUrl
            : "/recipes";

    private MealDbMealDetail? meal;
    private SavedRecipe? savedRecipe;
    private RecipeMatchStats? matchStats;
    private List<string> pantryNames = new();
    private bool isLoading = true;
    private bool isLoggedIn;
    private bool mealDbFailed = false;
    private string? userId;
    private bool showLoginPrompt;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        MealDb.ResetRequestFailure();
        meal = await MealDb.GetMealDetailsAsync(MealId);
        mealDbFailed = MealDb.LastRequestFailed;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isLoggedIn = user.Identity?.IsAuthenticated == true;

        if (isLoggedIn)
        {
            var appUser = await UserManager.GetUserAsync(user);
            userId = appUser?.Id;
            LoadSavedRecipe();

            if (userId != null && meal != null)
            {
                var pantry = await Pantry.GetPantryIngredientsAsync(userId);
                pantryNames = pantry.Select(i => i.Name).ToList();
                matchStats = RecipeMatchAnalyzer.Analyze(meal, pantryNames, pantryNames);
            }
        }

        isLoading = false;
    }

    private int servings = 2;
    private const int DefaultServings = 2;

    private void ChangeServings(int delta)
    {
        servings = Math.Max(1, servings + delta);
    }

    private string ScaleIngredientMeasure(string measure)
    {
        return servings == DefaultServings
            ? measure
            : ScaleMeasure(measure, servings, DefaultServings);
    }

    private static string ScaleMeasure(string measure, int servings, int baseServings)
    {
        if (string.IsNullOrWhiteSpace(measure))
            return measure;

        var trimmed = measure.Trim();
        var match = System.Text.RegularExpressions.Regex.Match(trimmed, "^(\\d+\\s+\\d+\\/\\d+|\\d+\\/\\d+|\\d+(?:\\.\\d+)?)(.*)$");
        if (!match.Success)
            return measure;

        var quantityText = match.Groups[1].Value;
        var remainder = match.Groups[2].Value.TrimStart();

        if (!TryParseQuantity(quantityText, out var quantity))
            return measure;

        var scaledQuantity = quantity * servings / baseServings;
        return $"{FormatQuantity(scaledQuantity)} {remainder}".TrimEnd();
    }

    private static bool TryParseQuantity(string text, out double quantity)
    {
        quantity = 0;
        text = text.Trim();

        if (text.Contains(' '))
        {
            var parts = text.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length == 2 && TryParseQuantity(parts[0], out var whole) && TryParseQuantity(parts[1], out var fraction))
            {
                quantity = whole + fraction;
                return true;
            }
        }

        if (text.Contains('/'))
        {
            var parts = text.Split('/', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length == 2 && double.TryParse(parts[0], NumberStyles.Number, CultureInfo.InvariantCulture, out var numerator)
                && double.TryParse(parts[1], NumberStyles.Number, CultureInfo.InvariantCulture, out var denominator)
                && denominator != 0)
            {
                quantity = numerator / denominator;
                return true;
            }
        }

        return double.TryParse(text, NumberStyles.Number, CultureInfo.InvariantCulture, out quantity);
    }

    private static string FormatQuantity(double quantity)
    {
        if (Math.Abs(quantity - Math.Round(quantity)) < 0.01)
            return Math.Round(quantity).ToString(CultureInfo.InvariantCulture);

        return quantity.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private void LoadSavedRecipe()
    {
        if (userId == null)
            return;

        savedRecipe = Db.SavedRecipes
            .FirstOrDefault(s => s.UserId == userId && s.MealDbId == MealId);
    }

    private async Task SaveMealDbRecipe()
    {
        if (!await EnsureLoggedInOrRedirectAsync() || meal == null)
            return;

        Db.SavedRecipes.Add(new SavedRecipe
        {
            UserId = userId!,
            MealDbId = meal.IdMeal,
            MealDbName = meal.StrMeal,
            MealDbImageUrl = meal.StrMealThumb,
            IsFavorite = false
        });

        try
        {
            await Db.SaveChangesAsync();
            LoadSavedRecipe();
        }
        catch (Exception)
        {
            Db.ChangeTracker.Clear();
            errorMessage = "The recipe could not be saved. Please try again.";
        }
    }

    private async Task ToggleFavorite()
    {
        if (!await EnsureLoggedInOrRedirectAsync() || meal == null)
            return;

        if (savedRecipe == null)
        {
            Db.SavedRecipes.Add(new SavedRecipe
            {
                UserId = userId!,
                MealDbId = meal.IdMeal,
                MealDbName = meal.StrMeal,
                MealDbImageUrl = meal.StrMealThumb,
                IsFavorite = true
            });
        }
        else
        {
            savedRecipe.IsFavorite = !savedRecipe.IsFavorite;
        }

        try
        {
            await Db.SaveChangesAsync();
            LoadSavedRecipe();
        }
        catch (Exception)
        {
            Db.ChangeTracker.Clear();
            errorMessage = "Your favorite could not be updated. Please try again.";
        }
    }

    private async Task ToggleSaved()
    {
        if (!await EnsureLoggedInOrRedirectAsync())
            return;

        if (savedRecipe == null)
        {
            await SaveMealDbRecipe();
            return;
        }

        try
        {
            Db.SavedRecipes.Remove(savedRecipe);
            await Db.SaveChangesAsync();
            savedRecipe = null;
        }
        catch (Exception)
        {
            Db.ChangeTracker.Clear();
            LoadSavedRecipe();
            errorMessage = "The saved recipe could not be updated. Please try again.";
        }
    }

    private async Task<bool> EnsureLoggedInOrRedirectAsync()
    {
        await RefreshUserStateAsync();

        if (isLoggedIn && userId != null)
            return true;

        showLoginPrompt = true;
        return false;
    }

    private void CloseLoginPrompt() => showLoginPrompt = false;
    private void CloseErrorPopup() => errorMessage = null;

    private void GoToLogin() => Nav.NavigateTo(GetLoginUrl());

    private void BackToResults()
    {
        RecipeState.ShowBackToBrowse = true;
        Nav.NavigateTo(BackToResultsUrl);
    }

    private async Task RefreshUserStateAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isLoggedIn = user.Identity?.IsAuthenticated == true;
        if (!isLoggedIn)
        {
            userId = null;
            savedRecipe = null;
            return;
        }

        var appUser = await UserManager.GetUserAsync(user);
        userId = appUser?.Id;
        LoadSavedRecipe();
    }

    private string GetLoginUrl()
    {
        var returnUrl = Uri.EscapeDataString(Nav.Uri);
        return $"/Account/Login?ReturnUrl={returnUrl}";
    }

    private DetailEstimate GetRecipeEstimate()
    {
        var ingredientCount = meal?.GetIngredientsWithMeasures().Count() ?? 8;
        var total = ingredientCount <= 6 ? 20 : ingredientCount <= 11 ? 30 : 40;
        var prep = Math.Max(10, total / 2);
        var cook = Math.Max(10, total - prep);
        var difficulty = ingredientCount >= 12 ? "Medium" : "Easy";

        return new DetailEstimate(prep, cook, prep + cook, difficulty);
    }

    private string GetRecipeDescription()
    {
        var category = string.IsNullOrWhiteSpace(meal?.StrCategory) ? "recipe" : meal.StrCategory.ToLowerInvariant();
        var area = string.IsNullOrWhiteSpace(meal?.StrArea) ? "" : $" with {meal.StrArea} flavor";
        return $"A quick and satisfying {category}{area}. Perfect for busy weeknights!";
    }

    private static string DisplayIngredient(string name) =>
        name switch
        {
            "Chicken Breast" => "Chicken",
            "Cheddar Cheese" => "Cheese",
            _ => name
        };

    private static string FormatIngredientLine(string measure, string ingredient)
    {
        var displayIngredient = DisplayIngredient(ingredient).ToLowerInvariant();
        return string.IsNullOrWhiteSpace(measure)
            ? DisplayIngredient(ingredient)
            : $"{measure.Trim()} {displayIngredient}";
    }

    private string GetCookingTip()
    {
        if (meal?.StrCategory?.Contains("Dessert", StringComparison.OrdinalIgnoreCase) == true)
            return "Let ingredients come to room temperature before mixing for a smoother texture.";

        if (meal?.StrArea?.Contains("Italian", StringComparison.OrdinalIgnoreCase) == true)
            return "Save a splash of pasta water to loosen the sauce before serving.";

        if (meal?.StrCategory?.Contains("Seafood", StringComparison.OrdinalIgnoreCase) == true)
            return "Cook seafood just until opaque so it stays tender.";

        return "For extra flavor, try adding a squeeze of lemon juice before serving!";
    }

    private record DetailEstimate(int PrepMinutes, int CookMinutes, int TotalMinutes, string Difficulty);
}
