@page "/"
@page "/home"

<PageTitle>ScrapeThePantry</PageTitle>

<div class="wireframe-page home-screen">

    <section class="wireframe-hero">
        <div class="hero-copy">
            <h1>Your pantry already knows what's for dinner</h1>
            <p class="hero-description">
                Pick what you have on hand and get recipe ideas without starting from scratch.
            </p>

            <div class="button-row">
                <a class="wire-btn primary" href="/recipes">Browse Recipes</a>
                <a class="wire-btn secondary" href="/ingredients">Add Ingredients to Your Pantry</a>
            </div>
        </div>
    </section>

    <section class="feature-strip" aria-labelledby="home-features-heading">
        <h2 id="home-features-heading" class="visually-hidden">Ways to get started</h2>
        <div class="wire-card-grid">
            <a class="wire-card" href="/ingredients">
                <div class="feature-icon"><i class="bi bi-basket" aria-hidden="true"></i></div>
                <h3>Build Your Pantry</h3>
                <p>Add the ingredients you already have at home.</p>
            </a>

            <a class="wire-card" href="/recipes">
                <div class="feature-icon"><i class="bi bi-journal-text" aria-hidden="true"></i></div>
                <h3>Match Recipes</h3>
                <p>Browse recipe ideas based on your selected ingredients.</p>
            </a>

            <a class="wire-card" href="/savedrecipes">
                <div class="feature-icon"><i class="bi bi-heart" aria-hidden="true"></i></div>
                <h3>Keep Favorites</h3>
                <p>Save recipes you want to make again later.</p>
            </a>
        </div>
    </section>

</div>
