@page "/savedrecipes"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using recipe_suggestions.Data
@using recipe_suggestions.Models
@using recipe_suggestions.Services

@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Saved Recipes</PageTitle>

<div class="wireframe-page compact-page saved-screen @(isLoggedIn ? "" : "auth-gate-screen")">

    @if (isLoggedIn)
    {
        <section class="saved-hero">
            <div>
                <h1>Saved Recipes</h1>
                <p>Recipes you’ve bookmarked and marked as favorites.</p>
            </div>
        </section>

        <div class="saved-tab-switch" role="tablist" aria-label="Filter saved recipes">
            <button type="button"
                    class="saved-tab @(activeTab == SavedTab.All ? "active" : "")"
                    role="tab"
                    aria-selected="@(activeTab == SavedTab.All)"
                    @onclick="() => SetTab(SavedTab.All)">
                <i class="bi @(activeTab == SavedTab.All ? "bi-bookmark-fill" : "bi-bookmark")" aria-hidden="true"></i>
                <span>All Recipes</span>
                <em>@savedRecipes.Count</em>
            </button>
            <button type="button"
                    class="saved-tab @(activeTab == SavedTab.Favorites ? "active" : "")"
                    role="tab"
                    aria-selected="@(activeTab == SavedTab.Favorites)"
                    @onclick="() => SetTab(SavedTab.Favorites)">
                <i class="bi @(activeTab == SavedTab.Favorites ? "bi-heart-fill" : "bi-heart")" aria-hidden="true"></i>
                <span>Favorites</span>
                <em>@FavoriteCount</em>
            </button>
        </div>
    }

    @if (!isLoggedIn)
    {
        <section class="auth-gate-card" aria-label="Sign in to continue">
            <div class="auth-gate-icon" aria-hidden="true">
                <i class="bi bi-bookmark"></i>
            </div>
            <h1>Saved Recipes</h1>
            <p>Sign in to keep bookmarks and favorites in one place.</p>
            <div class="auth-gate-actions">
                <a class="wire-btn primary" href="/Account/Login?ReturnUrl=%2Fsavedrecipes">Log in</a>
                <a class="wire-btn secondary" href="/Account/Register?ReturnUrl=%2Fsavedrecipes">Create account</a>
            </div>
        </section>
    }
    else if (!FilteredRecipes.Any())
    {
        <section class="wireframe-section empty-state saved-empty">
            <div class="empty-art">
                <i class="bi @(activeTab == SavedTab.Favorites ? "bi-heart-fill" : "bi-bookmark-fill")" aria-hidden="true"></i>
            </div>
            @if (activeTab == SavedTab.Favorites)
            {
                <h2>No favorites yet</h2>
                <p>Tap the heart on a recipe to keep your favorites here.</p>
            }
            else
            {
                <h2>No saved recipes yet</h2>
                <p>Bookmark recipes from search results or recipe details to find them again here.</p>
            }
            <a class="wire-btn primary" href="/ingredients">Find Recipes</a>
        </section>
    }
    else
    {
        <div class="saved-recipe-list" role="list">
            @foreach (var saved in FilteredRecipes)
            {
                <article class="saved-recipe-card @(saved.IsFavorite ? "is-favorite" : "")" role="listitem">
                    <a class="saved-recipe-media" href="/mealdbrecipe/@saved.MealDbId" aria-label="View @saved.MealDbName">
                        @if (!string.IsNullOrWhiteSpace(saved.MealDbImageUrl))
                        {
                            <img src="@saved.MealDbImageUrl" alt="" />
                        }
                        else
                        {
                            <div class="saved-recipe-fallback"><i class="bi bi-egg-fried" aria-hidden="true"></i></div>
                        }
                        <span class="saved-status-badge @(saved.IsFavorite ? "favorite" : "saved")">
                            <i class="bi @(saved.IsFavorite ? "bi-heart-fill" : "bi-bookmark-fill")" aria-hidden="true"></i>
                            @(saved.IsFavorite ? "Favorite" : "Saved")
                        </span>
                    </a>

                    <div class="saved-recipe-body">
                        <h2>
                            <a href="/mealdbrecipe/@saved.MealDbId">@saved.MealDbName</a>
                        </h2>
                        <div class="saved-recipe-meta">
                            <span><i class="bi bi-clock" aria-hidden="true"></i> @GetApproxTime(saved)</span>
                            <span aria-hidden="true">:</span>
                            <span><i class="bi bi-calendar3" aria-hidden="true"></i> Saved @saved.SavedAt.ToLocalTime().ToString("MMM d, yyyy")</span>
                        </div>
                    </div>

                    <div class="saved-recipe-actions">
                        <button type="button"
                                class="icon-button recipe-icon-button @(saved.IsFavorite ? "favorited" : "")"
                                aria-label="@(saved.IsFavorite ? $"Remove {saved.MealDbName} from favorites" : $"Favorite {saved.MealDbName}")"
                                aria-pressed="@saved.IsFavorite"
                                @onclick="() => ToggleFavorite(saved)">
                            <i class="bi @(saved.IsFavorite ? "bi-heart-fill" : "bi-heart")" aria-hidden="true"></i>
                        </button>

                        <button type="button"
                                class="icon-button recipe-icon-button saved"
                                aria-label="Unsave @saved.MealDbName"
                                aria-pressed="true"
                                @onclick="() => ToggleSaved(saved)">
                            <i class="bi bi-bookmark-fill" aria-hidden="true"></i>
                        </button>

                        <a class="wire-btn primary view-recipe-btn" href="/mealdbrecipe/@saved.MealDbId">
                            View Recipe
                        </a>
                    </div>
                </article>
            }
        </div>
    }

</div>

@code {
    private enum SavedTab { All, Favorites }

    private List<SavedRecipe> savedRecipes = new();
    private bool isLoggedIn;
    private string? userId;
    private SavedTab activeTab = SavedTab.All;

    [SupplyParameterFromQuery(Name = "tab")]
    public string? TabQuery { get; set; }

    private int FavoriteCount => savedRecipes.Count(r => r.IsFavorite);

    private IEnumerable<SavedRecipe> FilteredRecipes =>
        activeTab == SavedTab.Favorites
            ? savedRecipes.Where(r => r.IsFavorite)
            : savedRecipes;

    protected override async Task OnInitializedAsync()
    {
        if (string.Equals(TabQuery, "favorites", StringComparison.OrdinalIgnoreCase))
            activeTab = SavedTab.Favorites;

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;

        isLoggedIn = user.Identity?.IsAuthenticated == true;

        if (!isLoggedIn)
            return;

        var appUser = await UserManager.GetUserAsync(user);
        userId = appUser?.Id;

        LoadRecipes();
    }

    private void SetTab(SavedTab tab)
    {
        activeTab = tab;
    }

    private void LoadRecipes()
    {
        savedRecipes = Db.SavedRecipes
            .Where(r => r.UserId == userId && r.MealDbId != null)
            .OrderByDescending(r => r.IsFavorite)
            .ThenByDescending(r => r.SavedAt)
            .ToList();
    }

    private void ToggleFavorite(SavedRecipe recipe)
    {
        recipe.IsFavorite = !recipe.IsFavorite;
        Db.SaveChanges();
        LoadRecipes();
    }

    private void ToggleSaved(SavedRecipe recipe)
    {
        Db.SavedRecipes.Remove(recipe);
        Db.SaveChanges();
        LoadRecipes();
    }

    private static string GetApproxTime(SavedRecipe saved) =>
        RecipeTimeEstimator.FormatMinutes(
            RecipeTimeEstimator.Estimate(8, saved.MealDbName).TotalMinutes);
}
