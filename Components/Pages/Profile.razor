@page "/profile"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using recipe_suggestions.Data
@using recipe_suggestions.Services
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject PantryService Pantry

<PageTitle>Profile</PageTitle>

<div class="wireframe-page compact-page profile-screen">

    <section class="page-heading">
        <h1>Profile</h1>
        <p>Manage your account and view your activity.</p>
    </section>

    @if (!isLoggedIn)
    {
        <section class="wireframe-section empty-state">
            <div class="empty-art"><i class="bi bi-person-lock" aria-hidden="true"></i></div>
            <h2>Login required</h2>
            <p>Login to view your profile.</p>
            <a class="wire-btn primary" href="/Account/Login">Login</a>
        </section>
    }
    else
    {
        <section class="profile-grid">
            <div class="profile-card">
                <h2>Account Information</h2>
                <p class="profile-label">Email</p>
                <p>@email</p>

                <div class="button-row">
                    <a class="wire-btn secondary" href="/Account/Manage">Manage Account</a>
                </div>
            </div>

            <div class="profile-card">
                <h2>Your Stats</h2>
                <div class="stats-grid">
                    <a class="stat-card" href="/savedrecipes">
                        <span class="stat-icon-wrap"><i class="bi bi-journal-bookmark" aria-hidden="true"></i></span>
                        <strong>@savedCount</strong>
                        <p>Saved Recipes</p>
                    </a>

                    <a class="stat-card" href="/savedrecipes?tab=favorites">
                        <span class="stat-icon-wrap heart"><i class="bi bi-heart-fill" aria-hidden="true"></i></span>
                        <strong>@favoriteCount</strong>
                        <p>Favorites</p>
                    </a>

                    <a class="stat-card" href="/ingredients">
                        <span class="stat-icon-wrap custom"><i class="bi bi-basket" aria-hidden="true"></i></span>
                        <strong>@pantryCount</strong>
                        <p>Pantry Items</p>
                    </a>
                </div>
            </div>
        </section>
    }

</div>

@code {
    private bool isLoggedIn;
    private string email = "";
    private string? userId;

    private int savedCount;
    private int favoriteCount;
    private int pantryCount;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;

        isLoggedIn = user.Identity?.IsAuthenticated == true;

        if (!isLoggedIn)
            return;

        var appUser = await UserManager.GetUserAsync(user);

        userId = appUser?.Id;
        email = appUser?.Email ?? "";

        await LoadStats();
    }

    private async Task LoadStats()
    {
        if (userId == null)
            return;

        savedCount = Db.SavedRecipes.Count(r => r.UserId == userId);
        favoriteCount = Db.SavedRecipes.Count(r => r.UserId == userId && r.IsFavorite);
        pantryCount = await Pantry.GetPantryCountAsync(userId);
    }
}
