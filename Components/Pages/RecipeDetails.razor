@page "/recipe/{Id:int}"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using recipe_suggestions.Data
@using recipe_suggestions.Models
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Recipe Details</PageTitle>

@if (recipe == null)
{
    <div class="alert alert-warning">Recipe not found.</div>
    <a class="btn btn-primary" href="/ingredients">Back to Ingredients</a>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <h1>@recipe.Name</h1>
            <p class="lead">@recipe.Description</p>

            <p>
                <strong>Time:</strong> @recipe.PrepTimeMinutes minutes |
                <strong>Difficulty:</strong> @recipe.Difficulty
            </p>

            <hr />

            <h3>Ingredients</h3>
            <ul>
                @foreach (var item in recipe.RecipeIngredients)
                {
                    <li>@item.Quantity @item.Ingredient?.Name</li>
                }
            </ul>

            <h3>Instructions</h3>
            <p style="white-space: pre-line">@recipe.Instructions</p>

            <hr />

            @if (!isLoggedIn)
            {
                <div class="alert alert-info">
                    Log in to save recipes.
                </div>

                <a class="btn btn-primary" href="/Account/Login">Login</a>
            }
            else if (savedRecipe != null)
            {
                <button class="btn @(savedRecipe.IsFavorite ? "btn-warning" : "btn-outline-warning")"
                        @onclick="ToggleFavorite">
                    @(savedRecipe.IsFavorite ? "★ Favorited" : "☆ Mark Favorite")
                </button>

                <span class="ms-2 text-success">Saved</span>
            }
            else
            {
                <button class="btn btn-dark" @onclick="SaveRecipe">
                    Save Recipe
                </button>
            }

            <a class="btn btn-outline-secondary ms-2" href="/ingredients">
                Choose More Ingredients
            </a>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Recipe? recipe;
    private SavedRecipe? savedRecipe;
    private bool isLoggedIn;
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        recipe = Db.Recipes
            .Include(r => r.RecipeIngredients)
            .ThenInclude(ri => ri.Ingredient)
            .FirstOrDefault(r => r.Id == Id);

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isLoggedIn = user.Identity?.IsAuthenticated == true;

        if (isLoggedIn)
        {
            var appUser = await UserManager.GetUserAsync(user);
            userId = appUser?.Id;

            LoadSavedRecipe();
        }
    }

    private void LoadSavedRecipe()
    {
        if (userId == null)
            return;

        savedRecipe = Db.SavedRecipes
            .FirstOrDefault(s => s.UserId == userId && s.RecipeId == Id);
    }

    private void SaveRecipe()
    {
        if (userId == null)
            return;

        Db.SavedRecipes.Add(new SavedRecipe
        {
            UserId = userId,
            RecipeId = Id,
            IsFavorite = false
        });

        Db.SaveChanges();
        LoadSavedRecipe();
    }

    private void ToggleFavorite()
    {
        if (savedRecipe == null)
            return;

        savedRecipe.IsFavorite = !savedRecipe.IsFavorite;
        Db.SaveChanges();
    }
}