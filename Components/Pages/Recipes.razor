@page "/recipes"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using recipe_suggestions.Data
@using recipe_suggestions.Models
@using recipe_suggestions.Services
@inject MealDbService MealDb
@inject PantryService Pantry
@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject RecipeSearchState RecipeState
@inject GuestPantrySession GuestPantry

<PageTitle>Recipe Suggestions</PageTitle>

<div class="wireframe-page compact-page recipes-screen">

    @if (RecipeState.ShowBackToBrowse)
    {
        <button type="button" class="back-to-browse" @onclick="BackToBrowse">
            <i class="bi bi-arrow-left" aria-hidden="true"></i>
            Back to Browse
        </button>
    }

    <section class="wireframe-section page-heading recipes-hero">
        <div>
            <h1>Recipe Suggestions</h1>
            <p>Recipes matched using your selected ingredients.</p>
        </div>
        <div class="recipe-top-actions">
            <a class="wire-btn secondary pill-action" href="@EditPantryUrl">
                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                Add Missing
            </a>
        </div>
    </section>


    @if (isLoading)
    {
        <section class="wireframe-section empty-state">
            <div class="empty-art"><i class="bi bi-hourglass-split"></i></div>
            <h2>Finding recipes...</h2>
            <p>@loadingProgress</p>
        </section>
    }
    else if (searchIngredientIds.Count == 0 || noSearchResults)
    {
        @if (noSearchResults)
        {
            <div class="search-fallback-note" role="status">
                <i class="bi bi-info-circle" aria-hidden="true"></i>
                <span>None of these recipes use your ingredients. Browse recipes below instead.</span>
            </div>
        }
        else
        {
            <section class="wireframe-section empty-state">
                <div class="empty-art"><i class="bi bi-basket" aria-hidden="true"></i></div>
                <h2>Choose how to find recipes</h2>
                @if (pantryIngredientIds.Count > 0)
                {
                    <p>Use the ingredients saved in your pantry, add more ingredients before searching, or browse recipes below.</p>
                    <div class="button-row">
                        <button type="button" class="wire-btn primary" @onclick="SearchWithPantry">Use My Pantry</button>
                        <a class="wire-btn secondary" href="/ingredients">Add Ingredients</a>
                    </div>
                }
                else
                {
                    <p>Add ingredients to your pantry before searching, or browse recipes below.</p>
                    <a class="wire-btn primary" href="/ingredients">Add Ingredients to Pantry</a>
                }
            </section>
        }

        @if (!enrichedMatches.Any())
        {
            <section class="wireframe-section empty-state">
                <h2>No browse recipes available</h2>
                <p>Try again later or select ingredients from your pantry.</p>
            </section>
        }
        else
        {
            <section class="browse-heading">
                <h2>Browse Recipes</h2>
                <p>@(noSearchResults
                    ? "Popular recipes you can browse while you adjust your pantry."
                    : "Popular and easy recipes you can look through without selecting pantry ingredients.")</p>
                <div class="search-field browse-recipe-search">
                    <i class="bi bi-search" aria-hidden="true"></i>
                    <input type="search"
                           class="form-control"
                           placeholder="Search recipes by name..."
                           aria-label="Search browse recipes by name"
                           @bind="browseSearch"
                           @bind:event="oninput"
                           @bind:after="ApplyBrowseSearchAsync" />
                    @if (!string.IsNullOrWhiteSpace(browseSearch))
                    {
                        <button type="button" class="search-clear" aria-label="Clear recipe search" @onclick="ClearBrowseSearch">
                            <i class="bi bi-x-lg" aria-hidden="true"></i>
                        </button>
                    }
                </div>
            </section>

            @if (!FilteredMatches.Any())
            {
                <section class="wireframe-section empty-state browse-no-results">
                    <h2>No recipes found by that name</h2>
                    <p>Try a shorter or different recipe name.</p>
                </section>
            }

            <div class="recipe-suggestion-list">
                @foreach (var item in FilteredMatches)
                {
                    var stats = item.Stats;
                    var estimate = GetRecipeEstimate(item);

                    <article id="recipe-@item.Meal.IdMeal" class="recipe-suggestion-card @(stats.CanMakeWithPantry ? "can-make" : "")" role="link" tabindex="0" @onclick="() => OpenRecipe(item.Meal.IdMeal)">
                        <div class="suggestion-image-wrap">
                            <img src="@item.Meal.StrMealThumb" alt="Photo of @item.Meal.StrMeal" class="suggestion-image" />
                            <span class="suggestion-match-badge @(ShowHaveBadge ? "" : "browse-badge")">@GetBrowseOrMatchSummary(stats)</span>
                        </div>

                        <div class="suggestion-content">
                            <h2>@item.Meal.StrMeal</h2>
                            <div class="suggestion-meta">
                                <span><i class="bi bi-clock" aria-hidden="true"></i> @RecipeTimeEstimator.FormatMinutes(estimate.Minutes)</span>
                                <span aria-hidden="true">:</span>
                                <span><i class="bi bi-bar-chart-fill" aria-hidden="true"></i> @estimate.Difficulty</span>
                            </div>

                            <div class="suggestion-tags">
                                @{
                                    var tags = GetOrderedIngredientTags(item).ToList();
                                    var visibleTags = tags.Take(5).ToList();
                                }
                                @foreach (var ingredient in visibleTags)
                                {
                                    <span class="@(IsOwnedIngredient(ingredient) ? "owned" : null)">@ingredient</span>
                                }
                                @if (tags.Count > 5)
                                {
                                    <span class="tag-more" aria-hidden="true">...</span>
                                }
                            </div>
                        </div>

                        <div class="suggestion-actions">
                            <button type="button" class="icon-button recipe-icon-button @(IsFavorited(item.Meal.IdMeal) ? "favorited" : "")" @onclick:stopPropagation="true" @onclick="() => ToggleFavorite(item.Meal)" aria-label="@(IsFavorited(item.Meal.IdMeal) ? $"Unfavorite {item.Meal.StrMeal}" : $"Favorite {item.Meal.StrMeal}")" aria-pressed="@IsFavorited(item.Meal.IdMeal)">
                                <i class="bi @(IsFavorited(item.Meal.IdMeal) ? "bi-heart-fill" : "bi-heart")"></i>
                            </button>
                            <button type="button" class="icon-button recipe-icon-button @(IsSaved(item.Meal.IdMeal) ? "saved" : "")" @onclick:stopPropagation="true" @onclick="() => ToggleSaved(item.Meal)" aria-label="@(IsSaved(item.Meal.IdMeal) ? $"Unsave {item.Meal.StrMeal}" : $"Save {item.Meal.StrMeal}")" aria-pressed="@IsSaved(item.Meal.IdMeal)">
                                <i class="bi @(IsSaved(item.Meal.IdMeal) ? "bi-bookmark-fill" : "bi-bookmark")"></i>
                            </button>
                            <a class="wire-btn primary view-recipe-btn" href="@GetRecipeUrl(item.Meal.IdMeal)" @onclick:stopPropagation="true">View Recipe</a>
                        </div>
                    </article>
                }
            </div>

            @if (CanLoadMore)
            {
                <div class="load-more-row">
                    <button type="button" class="wire-btn secondary" disabled="@isLoadingMore" @onclick="LoadMoreAsync">
                        @(isLoadingMore ? $"Loading {PageSize} more..." : $"Load {PageSize} More ({remainingCount} left)")
                    </button>
                </div>
            }
            else
            {
                <p class="no-more-recipes">No more recipes to load</p>
            }
        }
    }
    else if (!FilteredMatches.Any())
    {
        <section class="wireframe-section empty-state">
            <h2>No recipes match this filter</h2>
            <p>Try another filter or add more ingredients to your pantry.</p>
            <button class="wire-btn secondary" @onclick="() => SetFilter(RecipeFilter.All)">Show All Matches</button>
        </section>
    }
    else
    {
        <div class="recipe-suggestion-list">
            @foreach (var item in FilteredMatches)
            {
                var stats = item.Stats;
                var estimate = GetRecipeEstimate(item);

                <article id="recipe-@item.Meal.IdMeal" class="recipe-suggestion-card @(stats.CanMakeWithPantry ? "can-make" : "")" role="link" tabindex="0" @onclick="() => OpenRecipe(item.Meal.IdMeal)">
                    <div class="suggestion-image-wrap">
                        <img src="@item.Meal.StrMealThumb" alt="Photo of @item.Meal.StrMeal" class="suggestion-image" />
                        <span class="suggestion-match-badge">@GetIngredientSummary(stats)</span>
                    </div>

                    <div class="suggestion-content">
                        <h2>@item.Meal.StrMeal</h2>
                        <div class="suggestion-meta">
                            <span><i class="bi bi-clock" aria-hidden="true"></i> @RecipeTimeEstimator.FormatMinutes(estimate.Minutes)</span>
                            <span aria-hidden="true">:</span>
                            <span><i class="bi bi-bar-chart-fill" aria-hidden="true"></i> @estimate.Difficulty</span>
                        </div>

                        <div class="suggestion-tags">
                            @{
                                var tags = GetOrderedIngredientTags(item).ToList();
                                var visibleTags = tags.Take(5).ToList();
                            }
                            @foreach (var ingredient in visibleTags)
                            {
                                <span class="@(IsOwnedIngredient(ingredient) ? "owned" : null)">@ingredient</span>
                            }
                            @if (tags.Count > 5)
                            {
                                <span class="tag-more" aria-hidden="true">...</span>
                            }
                        </div>
                    </div>

                    <div class="suggestion-actions">
                        <button type="button" class="icon-button recipe-icon-button @(IsFavorited(item.Meal.IdMeal) ? "favorited" : "")" @onclick:stopPropagation="true" @onclick="() => ToggleFavorite(item.Meal)" aria-label="@(IsFavorited(item.Meal.IdMeal) ? $"Unfavorite {item.Meal.StrMeal}" : $"Favorite {item.Meal.StrMeal}")" aria-pressed="@IsFavorited(item.Meal.IdMeal)">
                            <i class="bi @(IsFavorited(item.Meal.IdMeal) ? "bi-heart-fill" : "bi-heart")"></i>
                        </button>
                        <button type="button" class="icon-button recipe-icon-button @(IsSaved(item.Meal.IdMeal) ? "saved" : "")" @onclick:stopPropagation="true" @onclick="() => ToggleSaved(item.Meal)" aria-label="@(IsSaved(item.Meal.IdMeal) ? $"Unsave {item.Meal.StrMeal}" : $"Save {item.Meal.StrMeal}")" aria-pressed="@IsSaved(item.Meal.IdMeal)">
                            <i class="bi @(IsSaved(item.Meal.IdMeal) ? "bi-bookmark-fill" : "bi-bookmark")"></i>
                        </button>
                        <a class="wire-btn primary view-recipe-btn" href="@GetRecipeUrl(item.Meal.IdMeal)" @onclick:stopPropagation="true">View Recipe</a>
                    </div>
                </article>
            }
        </div>

        @if (CanLoadMore)
        {
            <div class="load-more-row">
                <button type="button" class="wire-btn secondary" disabled="@isLoadingMore" @onclick="LoadMoreAsync">
                    @(isLoadingMore ? $"Loading {PageSize} more..." : $"Load {PageSize} More ({remainingCount} left)")
                </button>
            </div>
        }
        else
        {
            <p class="no-more-recipes">No more recipes to load</p>
        }
    }

    @if (pendingAuthMeal != null)
    {
        <div class="modal-backdrop" @onclick="CloseRecipeAuthPrompt">
            <section class="app-modal recipe-auth-modal" role="dialog" aria-modal="true" aria-labelledby="recipe-auth-title" @onclick:stopPropagation="true">
                <button type="button" class="modal-close" aria-label="Close" @onclick="CloseRecipeAuthPrompt">&times;</button>
                <h2 id="recipe-auth-title">Log in to @pendingAuthAction recipes</h2>
                <p>@pendingAuthMeal.StrMeal can be viewed now. Log in or sign up to save and favorite recipes.</p>
                <div class="modal-actions recipe-auth-actions">
                    <button type="button" class="wire-btn secondary" @onclick="() => OpenRecipe(pendingAuthMeal.IdMeal)">View Recipe</button>
                    <button type="button" class="wire-btn secondary" @onclick="GoToRegister">Sign Up</button>
                    <button type="button" class="wire-btn primary" @onclick="GoToLogin">Log In</button>
                </div>
            </section>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="modal-backdrop" @onclick="CloseErrorPopup">
            <section class="app-modal recipe-auth-modal" role="alertdialog" aria-modal="true" aria-labelledby="recipe-error-title" @onclick:stopPropagation="true">
                <button type="button" class="modal-close" aria-label="Close" @onclick="CloseErrorPopup">&times;</button>
                <h2 id="recipe-error-title">Something went wrong</h2>
                <p>@errorMessage</p>
                <div class="modal-actions">
                    <button type="button" class="wire-btn primary" @onclick="CloseErrorPopup">OK</button>
                </div>
            </section>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "ingredients")]
    public string? IngredientQuery { get; set; }

    [SupplyParameterFromQuery(Name = "filter")]
    public string? FilterQuery { get; set; }

    [SupplyParameterFromQuery(Name = "browse")]
    public string? BrowseQuery { get; set; }

    private List<int> searchIngredientIds => RecipeState.SearchIngredientIds;
    private HashSet<int> pantryIngredientIds => RecipeState.PantryIngredientIds;
    private List<string> pantryNames => RecipeState.PantryNames;
    private List<string> searchNames => RecipeState.SearchNames;
    private List<EnrichedRecipeMatch> enrichedMatches => RecipeState.EnrichedMatches;
    private List<EnrichedRecipeMatch> recipeCandidates => RecipeState.RecipeCandidates;
    private HashSet<string> favoritedMealIds => RecipeState.FavoritedMealIds;
    private HashSet<string> savedMealIds => RecipeState.SavedMealIds;
    private string browseSearch
    {
        get => RecipeState.BrowseSearch;
        set => RecipeState.BrowseSearch = value;
    }
    private RecipeFilter filterMode
    {
        get => RecipeState.FilterMode;
        set => RecipeState.FilterMode = value;
    }
    private bool isLoading
    {
        get => RecipeState.IsLoading;
        set => RecipeState.IsLoading = value;
    }
    private bool isLoadingMore;
    private bool isLoggedIn;
    private string? userId
    {
        get => RecipeState.UserId;
        set => RecipeState.UserId = value;
    }
    private string loadingProgress
    {
        get => RecipeState.LoadingProgress;
        set => RecipeState.LoadingProgress = value;
    }
    private int allCount
    {
        get => RecipeState.AllCount;
        set => RecipeState.AllCount = value;
    }
    private int pantryCompleteCount
    {
        get => RecipeState.PantryCompleteCount;
        set => RecipeState.PantryCompleteCount = value;
    }
    private int searchCompleteCount
    {
        get => RecipeState.SearchCompleteCount;
        set => RecipeState.SearchCompleteCount = value;
    }
    private bool searchStarted
    {
        get => RecipeState.SearchStarted;
        set => RecipeState.SearchStarted = value;
    }
    private bool noSearchResults
    {
        get => RecipeState.NoSearchResults;
        set => RecipeState.NoSearchResults = value;
    }
    private int nextCandidateIndex
    {
        get => RecipeState.NextCandidateIndex;
        set => RecipeState.NextCandidateIndex = value;
    }
    private MealDbMealSummary? pendingAuthMeal;
    private string pendingAuthAction = "save";
    private string? errorMessage;
    private bool needsSearch;
    private const int InitialPageSize = 4;
    private const int PageSize = 20;

    private string EditPantryUrl =>
        searchIngredientIds.Count == 0
            ? "/ingredients"
            : $"/ingredients?selected={string.Join(",", searchIngredientIds)}";

    private IEnumerable<EnrichedRecipeMatch> FilteredMatches => filterMode switch
    {
        _ when searchIngredientIds.Count == 0 || noSearchResults => enrichedMatches.Where(MatchesBrowseSearch),
        recipe_suggestions.Models.RecipeFilter.PantryComplete => enrichedMatches.Where(m => m.Stats.CanMakeWithPantry),
        recipe_suggestions.Models.RecipeFilter.SearchComplete => enrichedMatches.Where(m => m.Stats.CanMakeWithSearch),
        _ => enrichedMatches
    };

    private int remainingCount => Math.Max(0, recipeCandidates.Count - nextCandidateIndex);
    private bool CanLoadMore => remainingCount > 0 && !isLoading && string.IsNullOrWhiteSpace(browseSearch);

    protected override void OnParametersSet()
    {
        var currentIngredientQuery = IngredientQuery?.Trim() ?? string.Empty;
        var currentFilterQuery = FilterQuery?.Trim().ToLowerInvariant() ?? string.Empty;

        if (RecipeState.SearchStarted &&
            RecipeState.IngredientQuery == currentIngredientQuery &&
            RecipeState.FilterQuery == currentFilterQuery)
        {
            needsSearch = false;
            return;
        }

        RecipeState.Clear();
        RecipeState.IngredientQuery = currentIngredientQuery;
        RecipeState.FilterQuery = currentFilterQuery;
        needsSearch = true;

        if (!string.IsNullOrWhiteSpace(FilterQuery))
        {
            filterMode = FilterQuery.ToLowerInvariant() switch
            {
                "pantry" => RecipeFilter.PantryComplete,
                "selected" => RecipeFilter.SearchComplete,
                _ => RecipeFilter.All
            };
        }

        if (!string.IsNullOrWhiteSpace(IngredientQuery))
        {
            searchIngredientIds.Clear();
            searchIngredientIds.AddRange(IngredientQuery
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(s => int.TryParse(s, out var id) ? id : 0)
                .Where(id => id > 0));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshUserStateAsync();

            if (!needsSearch)
                StateHasChanged();
        }

        if (!needsSearch)
            return;

        needsSearch = false;
        searchStarted = true;
        await RunSearchAsync();
    }

    private async Task RunSearchAsync()
    {
        await RefreshUserStateAsync();

        if (searchIngredientIds.Count == 0)
        {
            loadingProgress = "Loading recipes to browse...";
            StateHasChanged();

            var browseMeals = RecipeState.BrowseRecipesCache.Any()
                ? RecipeState.BrowseRecipesCache
                : await MealDb.GetBrowseRecipesAsync();

            if (!RecipeState.BrowseRecipesCache.Any())
                RecipeState.BrowseRecipesCache.AddRange(browseMeals);

            recipeCandidates.Clear();
            recipeCandidates.AddRange(browseMeals
                .OrderBy(_ => Random.Shared.Next())
                .Select(meal => new EnrichedRecipeMatch { Meal = meal }));

            nextCandidateIndex = 0;
            await HydrateNextBatchAsync(InitialPageSize);
            isLoading = false;
            StateHasChanged();
            return;
        }

        var searchIngredientsById = Db.Ingredients
            .Where(i => searchIngredientIds.Contains(i.Id))
            .ToDictionary(i => i.Id);

        var searchIngredients = searchIngredientIds
            .Where(id => searchIngredientsById.ContainsKey(id))
            .Select(id => searchIngredientsById[id])
            .ToList();

        RecipeState.SearchNames.Clear();
        RecipeState.SearchNames.AddRange(searchIngredients.Select(i => i.Name));

        // Guests: ensure pantry ownership mirrors selected pantry when Find Recipes set it.
        if (!isLoggedIn && RecipeState.PantryNames.Count == 0 && searchIngredients.Count > 0)
        {
            RecipeState.PantryNames.AddRange(searchIngredients.Select(i => i.Name));
            RecipeState.PantryIngredientIds.UnionWith(searchIngredientIds);
        }

        loadingProgress = "Searching meals from TheMealDB...";
        StateHasChanged();

        var matchDictionary = new Dictionary<string, EnrichedRecipeMatch>();
        MealDb.ResetRequestFailure();

        var searchTasks = searchIngredients
            .Take(15)
            .Select(async ingredient => new
            {
                Ingredient = ingredient.Name,
                Meals = await MealDb.SearchByIngredientAsync(ingredient.Name)
            })
            .ToList();

        var searchResults = await Task.WhenAll(searchTasks);

        foreach (var result in searchResults)
        {
            foreach (var meal in result.Meals.Take(30))
            {
                if (!matchDictionary.TryGetValue(meal.IdMeal, out var match))
                {
                    match = new EnrichedRecipeMatch
                    {
                        Meal = meal,
                        MatchedSearchNames = new List<string>()
                    };
                    matchDictionary[meal.IdMeal] = match;
                }

                match.SearchHitCount++;
                match.MatchedSearchNames.Add(result.Ingredient);
            }
        }

        RecipeState.RecipeCandidates.Clear();
        RecipeState.RecipeCandidates.AddRange(matchDictionary.Values
            .OrderByDescending(m => m.SearchHitCount)
            .ThenBy(m => m.Meal.StrMeal));

        if (RecipeState.RecipeCandidates.Count == 0)
        {
            noSearchResults = true;
            var browseMeals = RecipeState.BrowseRecipesCache.Any()
                ? RecipeState.BrowseRecipesCache
                : await MealDb.GetBrowseRecipesAsync();

            if (!RecipeState.BrowseRecipesCache.Any())
                RecipeState.BrowseRecipesCache.AddRange(browseMeals);

            RecipeState.RecipeCandidates.AddRange(browseMeals
                .OrderBy(_ => Random.Shared.Next())
                .Select(browseMeal => new EnrichedRecipeMatch { Meal = browseMeal }));
        }
        nextCandidateIndex = 0;

        loadingProgress = recipeCandidates.Count == 0
            ? "No recipes found for those ingredients."
            : $"Loading the first {Math.Min(InitialPageSize, recipeCandidates.Count)} recipes...";

        await HydrateNextBatchAsync(InitialPageSize);

        // MealDB sometimes returns filter matches that do not actually contain the ingredient text.
        if (!noSearchResults && enrichedMatches.Count == 0)
        {
            noSearchResults = true;
            recipeCandidates.Clear();
            nextCandidateIndex = 0;

            var browseMeals = RecipeState.BrowseRecipesCache.Any()
                ? RecipeState.BrowseRecipesCache
                : await MealDb.GetBrowseRecipesAsync();

            if (!RecipeState.BrowseRecipesCache.Any())
                RecipeState.BrowseRecipesCache.AddRange(browseMeals);

            recipeCandidates.AddRange(browseMeals
                .OrderBy(_ => Random.Shared.Next())
                .Select(browseMeal => new EnrichedRecipeMatch { Meal = browseMeal }));

            await HydrateNextBatchAsync(InitialPageSize);
        }

        isLoading = false;
        StateHasChanged();
    }

    private async Task RefreshUserStateAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        isLoggedIn = auth.User.Identity?.IsAuthenticated == true;

        if (!isLoggedIn)
        {
            userId = null;
            RecipeState.FavoritedMealIds.Clear();
            RecipeState.SavedMealIds.Clear();
            // Keep guest temporary pantry from the Ingredients page (never invent it from search).
            if (RecipeState.PantryIngredientIds.Count == 0)
                RecipeState.PantryNames.Clear();

            if (RecipeState.PantryIngredientIds.Count > 0 || searchIngredientIds.Count > 0)
                await GuestPantry.SaveAsync(RecipeState.PantryIngredientIds.Concat(searchIngredientIds));

            return;
        }

        userId = (await UserManager.GetUserAsync(auth.User))?.Id;
        if (userId == null)
            return;

        await MergeGuestSelectionsIntoPantryAsync();

        var pantry = await Pantry.GetPantryIngredientsAsync(userId);
        RecipeState.PantryNames.Clear();
        RecipeState.PantryNames.AddRange(pantry.Select(i => i.Name));
        RecipeState.PantryIngredientIds.Clear();
        RecipeState.PantryIngredientIds.UnionWith(pantry.Select(i => i.Id));

        RefreshSavedRecipeState();
    }

    private async Task MergeGuestSelectionsIntoPantryAsync()
    {
        if (userId == null)
            return;

        var pending = new List<int>();
        pending.AddRange(await GuestPantry.TakeAsync());
        pending.AddRange(searchIngredientIds);
        pending.AddRange(RecipeState.PantryIngredientIds);
        pending.AddRange(RecipeState.SearchIngredientIds);

        if (pending.Count == 0)
            return;

        await Pantry.AddManyToPantryAsync(userId, pending);
    }

    private async Task HydrateNextBatchAsync(int count)
    {
        var currentMatches = RecipeState.EnrichedMatches.ToList();
        var added = 0;
        var isIngredientSearch = searchIngredientIds.Count > 0 && !noSearchResults;

        while (added < count && nextCandidateIndex < recipeCandidates.Count)
        {
            var take = Math.Min(count - added, recipeCandidates.Count - nextCandidateIndex);
            var batch = recipeCandidates
                .Skip(nextCandidateIndex)
                .Take(take)
                .ToList();

            nextCandidateIndex += batch.Count;

            var hydratedCandidates = await Task.WhenAll(batch.Select(async candidate =>
            {
                candidate.Detail = await MealDb.GetMealDetailsAsync(candidate.Meal.IdMeal);
                return candidate;
            }));

            foreach (var candidate in hydratedCandidates)
            {
                if (candidate.Detail == null)
                    continue;

                candidate.Stats = RecipeMatchAnalyzer.Analyze(candidate.Detail, pantryNames, searchNames);

                // Ingredient search results must actually contain searched ingredients.
                if (isIngredientSearch && candidate.Stats.HaveFromSearch == 0)
                    continue;

                currentMatches.Add(candidate);
                added++;

                if (added >= count)
                    break;
            }
        }

        RecipeState.EnrichedMatches.Clear();
        RecipeState.EnrichedMatches.AddRange(SortMatches(currentMatches, isIngredientSearch));

        allCount = RecipeState.EnrichedMatches.Count;
        pantryCompleteCount = RecipeState.EnrichedMatches.Count(m => m.Stats.CanMakeWithPantry);
        searchCompleteCount = RecipeState.EnrichedMatches.Count(m => m.Stats.CanMakeWithSearch);
    }

    private IEnumerable<EnrichedRecipeMatch> SortMatches(IEnumerable<EnrichedRecipeMatch> matches, bool isIngredientSearch)
    {
        // Most have → least to buy → earlier pantry/search list matches first.
        var ordered = matches
            .OrderByDescending(m => m.Stats.HaveFromPantry)
            .ThenBy(m => m.Stats.BuyCount)
            .ThenByDescending(m => m.Stats.PriorityScore);

        if (isIngredientSearch)
        {
            return ordered
                .ThenByDescending(m => m.SearchHitCount)
                .ThenBy(m => m.Meal.StrMeal);
        }

        return ordered.ThenBy(m => m.Meal.StrMeal);
    }

    private async Task LoadMoreAsync()
    {
        if (isLoadingMore || !CanLoadMore)
            return;

        isLoadingMore = true;
        await HydrateNextBatchAsync(PageSize);
        isLoadingMore = false;
        StateHasChanged();
    }

    private void SetFilter(RecipeFilter mode) => filterMode = mode;

    private bool MatchesBrowseSearch(EnrichedRecipeMatch match) =>
        string.IsNullOrWhiteSpace(browseSearch) ||
        match.Meal.StrMeal.Contains(browseSearch.Trim(), StringComparison.OrdinalIgnoreCase);

    private async Task ApplyBrowseSearchAsync()
    {
        if (string.IsNullOrWhiteSpace(browseSearch))
            return;

        var loadedIds = enrichedMatches.Select(match => match.Meal.IdMeal).ToHashSet();
        var matchingCandidates = recipeCandidates
            .Where(candidate => candidate.Meal.StrMeal.Contains(browseSearch.Trim(), StringComparison.OrdinalIgnoreCase))
            .Where(candidate => !loadedIds.Contains(candidate.Meal.IdMeal))
            .Take(PageSize)
            .ToList();

        if (matchingCandidates.Count == 0)
            return;

        var hydrated = await Task.WhenAll(matchingCandidates.Select(async candidate =>
        {
            candidate.Detail = await MealDb.GetMealDetailsAsync(candidate.Meal.IdMeal);
            if (candidate.Detail != null)
                candidate.Stats = RecipeMatchAnalyzer.Analyze(candidate.Detail, pantryNames, searchNames);
            return candidate;
        }));

        enrichedMatches.AddRange(hydrated.Where(candidate => candidate.Detail != null));
        StateHasChanged();
    }

    private void ClearBrowseSearch() => browseSearch = string.Empty;

    private void SearchWithPantry()
    {
        if (pantryIngredientIds.Count == 0)
            return;

        Nav.NavigateTo($"/recipes?ingredients={string.Join(",", pantryIngredientIds.Order())}");
    }

    private void BackToBrowse()
    {
        RecipeState.Clear();
        Nav.NavigateTo($"/recipes?browse={Guid.NewGuid():N}");
    }

    private void SortByTime()
    {
        RecipeState.EnrichedMatches.Sort((x, y) =>
        {
            var first = GetEstimatedMinutes(x);
            var second = GetEstimatedMinutes(y);
            var compare = first.CompareTo(second);
            return compare != 0 ? compare : string.CompareOrdinal(x.Meal.StrMeal, y.Meal.StrMeal);
        });
    }

    private bool IsFavorited(string mealId) => favoritedMealIds.Contains(mealId);
    private bool IsSaved(string mealId) => savedMealIds.Contains(mealId);

    private bool ShowHaveBadge => pantryNames.Count > 0 || searchNames.Count > 0;

    private string GetBrowseOrMatchSummary(RecipeMatchStats stats)
    {
        if (!ShowHaveBadge)
            return "Browse";

        return GetIngredientSummary(stats);
    }

    private bool IsOwnedIngredient(string ingredient) =>
        pantryNames.Any(p => IngredientMatcher.Matches(p, ingredient));

    private static string GetIngredientSummary(RecipeMatchStats stats)
    {
        if (stats.TotalIngredients == 0)
            return "Ingredients loading";

        return $"{stats.HaveFromPantry} have / {stats.BuyCount} buy";
    }

    private RecipeEstimate GetRecipeEstimate(EnrichedRecipeMatch match)
    {
        var estimate = RecipeTimeEstimator.Estimate(
            Math.Max(match.Stats.TotalIngredients, 4),
            match.Meal.StrMeal,
            match.Detail?.StrCategory);

        return new RecipeEstimate(estimate.TotalMinutes, estimate.Difficulty);
    }

    private int GetEstimatedMinutes(EnrichedRecipeMatch match) =>
        GetRecipeEstimate(match).Minutes;

    private IEnumerable<string> GetIngredientTags(EnrichedRecipeMatch match)
    {
        if (match.Detail != null)
        {
            return match.Detail.GetIngredientsWithMeasures()
                .Select(i => DisplayIngredient(i.Ingredient))
                .Where(i => !string.IsNullOrWhiteSpace(i))
                .Distinct(StringComparer.OrdinalIgnoreCase);
        }

        return match.MatchedSearchNames.Select(DisplayIngredient);
    }

    private IEnumerable<string> GetOrderedIngredientTags(EnrichedRecipeMatch match)
    {
        var tags = GetIngredientTags(match).ToList();
        return tags
            .Where(IsOwnedIngredient)
            .Concat(tags.Where(tag => !IsOwnedIngredient(tag)));
    }

    private static string DisplayIngredient(string name) =>
        name switch
        {
            "Chicken Breast" => "Chicken",
            "Cheddar Cheese" => "Cheese",
            _ => name
        };

    private record RecipeEstimate(int Minutes, string Difficulty);

    private void OpenRecipe(string mealId)
    {
        Nav.NavigateTo(GetRecipeUrl(mealId));
    }

    private string GetRecipeUrl(string mealId)
    {
        var resultsPath = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        var returnUrl = Uri.EscapeDataString($"{resultsPath}#recipe-{mealId}");
        var source = searchIngredientIds.Count == 0 || noSearchResults ? "source=browse&" : "";
        return $"/mealdbrecipe/{mealId}?{source}returnUrl={returnUrl}";
    }

    private async Task ToggleFavorite(MealDbMealSummary meal)
    {
        if (!await EnsureLoggedInForRecipeActionAsync(meal, "favorite"))
            return;

        try
        {
            var existing = Db.SavedRecipes.FirstOrDefault(r => r.UserId == userId && r.MealDbId == meal.IdMeal);
            if (existing == null)
            {
                Db.SavedRecipes.Add(new SavedRecipe
                {
                    UserId = userId!, MealDbId = meal.IdMeal, MealDbName = meal.StrMeal,
                    MealDbImageUrl = meal.StrMealThumb, IsFavorite = true
                });
            }
            else
            {
                existing.IsFavorite = !existing.IsFavorite;
            }

            await Db.SaveChangesAsync();
            RefreshSavedRecipeState();
        }
        catch (Exception)
        {
            Db.ChangeTracker.Clear();
            errorMessage = "Your favorite could not be updated. Please try again.";
        }
    }

    private async Task ToggleSaved(MealDbMealSummary meal)
    {
        if (!await EnsureLoggedInForRecipeActionAsync(meal, "save"))
            return;

        try
        {
            var existing = Db.SavedRecipes.FirstOrDefault(r => r.UserId == userId && r.MealDbId == meal.IdMeal);
            if (existing == null)
            {
                Db.SavedRecipes.Add(new SavedRecipe
                {
                    UserId = userId!, MealDbId = meal.IdMeal, MealDbName = meal.StrMeal,
                    MealDbImageUrl = meal.StrMealThumb, IsFavorite = false
                });
            }
            else
            {
                Db.SavedRecipes.Remove(existing);
            }

            await Db.SaveChangesAsync();
            RefreshSavedRecipeState();
        }
        catch (Exception)
        {
            Db.ChangeTracker.Clear();
            errorMessage = "The recipe could not be saved. Please try again.";
        }
    }

    private async Task<bool> EnsureLoggedInForRecipeActionAsync(MealDbMealSummary meal, string action)
    {
        await RefreshUserStateAsync();

        if (isLoggedIn && userId != null)
            return true;

        pendingAuthMeal = meal;
        pendingAuthAction = action;
        return false;
    }

    private void CloseRecipeAuthPrompt()
    {
        pendingAuthMeal = null;
        pendingAuthAction = "save";
    }

    private void CloseErrorPopup() => errorMessage = null;

    private async Task GoToLogin()
    {
        if (searchIngredientIds.Count > 0 || RecipeState.PantryIngredientIds.Count > 0)
            await GuestPantry.SaveAsync(RecipeState.PantryIngredientIds.Concat(searchIngredientIds));

        Nav.NavigateTo($"/Account/Login?ReturnUrl={GetCurrentReturnUrl()}");
    }

    private async Task GoToRegister()
    {
        if (searchIngredientIds.Count > 0 || RecipeState.PantryIngredientIds.Count > 0)
            await GuestPantry.SaveAsync(RecipeState.PantryIngredientIds.Concat(searchIngredientIds));

        Nav.NavigateTo($"/Account/Register?ReturnUrl={GetCurrentReturnUrl()}");
    }

    private string GetCurrentReturnUrl()
    {
        return Uri.EscapeDataString("/" + Nav.ToBaseRelativePath(Nav.Uri));
    }

    private void RefreshSavedRecipeState()
    {
        RecipeState.FavoritedMealIds.Clear();
        RecipeState.FavoritedMealIds.UnionWith(Db.SavedRecipes
            .Where(r => r.UserId == userId && r.IsFavorite && r.MealDbId != null)
            .Select(r => r.MealDbId!));
        RecipeState.SavedMealIds.Clear();
        RecipeState.SavedMealIds.UnionWith(Db.SavedRecipes
            .Where(r => r.UserId == userId && r.MealDbId != null)
            .Select(r => r.MealDbId!));
    }

}
