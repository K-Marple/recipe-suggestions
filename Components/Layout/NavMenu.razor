@implements IDisposable
@inject NavigationManager NavigationManager
@inject recipe_suggestions.Services.RecipeSearchState RecipeState

<aside class="app-sidebar">
    <nav class="sidebar-nav" aria-label="Main navigation">
        <NavLink href="" Match="NavLinkMatch.All"><span class="nav-icon"><i class="bi bi-house" aria-hidden="true"></i></span> Home</NavLink>
        <NavLink href="ingredients"><span class="nav-icon"><i class="bi bi-basket" aria-hidden="true"></i></span> My Pantry</NavLink>
        <a href="/recipes" class="@(currentUrl?.StartsWith("recipes", StringComparison.OrdinalIgnoreCase) == true ? "active" : null)" @onclick="BrowseRecipes" @onclick:preventDefault="true"><span class="nav-icon"><i class="bi bi-journal-text" aria-hidden="true"></i></span> Recipes</a>
        <NavLink href="savedrecipes"><span class="nav-icon"><i class="bi bi-heart" aria-hidden="true"></i></span> Saved Recipes</NavLink>
        <NavLink href="profile"><span class="nav-icon"><i class="bi bi-person" aria-hidden="true"></i></span> Profile</NavLink>
    </nav>

    <div class="sidebar-auth">
        <AuthorizeView>
            <NotAuthorized>
                <NavLink href="Account/Login"><span class="nav-icon"><i class="bi bi-box-arrow-in-right" aria-hidden="true"></i></span> Login</NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</aside>

@code {
    private string? currentUrl;

    private void BrowseRecipes()
    {
        RecipeState.Clear();
        NavigationManager.NavigateTo($"/recipes?browse={Guid.NewGuid():N}");
    }

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
